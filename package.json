{
  "name": "csp451-actions-seed",
  "version": "1.0.0",
  "description": "Seed repo for GitHub Actions CI exercise with code scanning and coverage gates",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest --ci --coverage",
    "audit:check": "npm audit --audit-level=moderate",
    "build": "node -e \"console.log('Build step OK')\""
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^6.3.4"
  }
}
